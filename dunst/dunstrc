# Dunst Config - Catppuccin Mocha
# Facilitador de cores (basta copiar e colar nos campos abaixo se quiser mudar)
# Base: #1e1e2e
# Text: #cdd6f4
# Blue: #89b4fa
# Green: #a6e3a1
# Red: #f38ba8
# Yellow: #f9e2af

[global]
    ### Display ###
    monitor = 0
    follow = mouse
    
    ### Geometry ###
    width = 350
    height = (0, 300)
    origin = top-right
    offset = (20, 50)
    scale = 0
    notification_limit = 5

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 350
    progress_bar_corner_radius = 10
    
    ### UI Elements ###
    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 10
    frame_width = 2
    gap_size = 5
    separator_color = frame
    sort = yes
    idle_threshold = 120

    ### Text ###
    font = JetBrains Mono 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###
    enable_recursive_icon_lookup = true
    icon_theme = "Adwaita"
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Advanced ###
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true
    corner_radius = 10
    corners = all
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    # Cores Catppuccin Mocha
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 5
    default_icon = dialog-information

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#a6e3a1"
    timeout = 10
    default_icon = dialog-information

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#f38ba8"
    timeout = 0
    default_icon = dialog-warning

# Regras customizadas úteis
[backlight]
    summary = "Backlight"
    set_stack_tag = "backlight"

[volume]
    summary = "Volume"
    set_stack_tag = "volume"
